[default]
region            = eu-central-1
output            = json
granted_color     = black
granted_icon      = circle

[profile development]
role_arn          = <role_arn>
source_profile    = default
role_session_name = development
region            = eu-central-1
granted_color     = yellow
granted_icon      = fingerprint

[profile operations]
role_arn          = <role_arn>
source_profile    = default
role_session_name = operations
region            = eu-central-1
granted_color     = blue
granted_icon      = briefcase

[profile production]
role_arn          = <role_arn>
source_profile    = default
role_session_name = production
region            = eu-central-1
granted_color     = red
granted_icon      = fingerprint

[profile staging]
role_arn          = <role_arn>
source_profile    = default
role_session_name = staging
region            = eu-central-1
granted_color     = orange
granted_icon      = fingerprint

[profile default]
credential_process = granted credential-process --profile=default
