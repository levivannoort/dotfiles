[user]
  name = Levi van Noort
  email = 73097785+levivannoort@users.noreply.github.com

[includeIf "gitdir:~/work/"]
    path = ~/work/.gitconfig

[core]
  excludesfile = ~/.gitignore
  editor = zed

[init]
  defaultBranch = main

[url "git@github.com:"]
  insteadOf = https://github.com/

[url "git@gitlab.com:"]
  insteadOf = https://gitlab.com/
